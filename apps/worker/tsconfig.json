{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@shared/*": ["../../packages/shared/src/*"],
      "@ai/*": ["../../packages/ai/src/*"],
      "@video/*": ["../../packages/video/src/*"],
      "@subtitles/*": ["../../packages/subtitles/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
